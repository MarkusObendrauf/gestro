{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gestro",
  "version": "0.1.3",
  "identifier": "com.gestro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "gestro — Settings",
        "width": 800,
        "height": 750,
        "minWidth": 700,
        "minHeight": 750,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Markus Obendrauf",
    "linux": {
      "rpm": {
        "files": {
          "/usr/share/metainfo/com.gestro.app.metainfo.xml": "metainfo.xml"
        }
      },
      "deb": {
        "files": {
          "/usr/share/metainfo/com.gestro.app.metainfo.xml": "metainfo.xml"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
